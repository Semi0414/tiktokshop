APP_NAME=Bagisto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_DEBUG_ALLOWED_IPS=
APP_URL=http://localhost
# true = skip Bagisto web installer (/install). Use on live/staging when DB is already migrated and seeded.
APP_INSTALLED=false
APP_ADMIN_URL=admin
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_CURRENCY=USD

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PREFIX=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

# Use smtp for real delivery. Example (SSL): host mail.example.com, port 465, encryption ssl
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=ssl
MAIL_VERIFY_PEER=true

# Optional: force which Laravel mailer Super Admin outbound emails use (defaults to MAIL_MAILER)
# SUPERADMIN_MAIL_MAILER=smtp
#
# Super Admin HTML emails (welcome + email management): use the same domain your SMTP allows.
# If the host bounces with “Mail Delivery Failed: returning message to sender”, set MAIL_FROM_ADDRESS
# to the mailbox you authenticate with (often equals MAIL_USERNAME) and set MAIL_EHLO_DOMAIN to your site domain.
# SUPERADMIN_MAIL_FROM_ADDRESS=shop@example.com
# SUPERADMIN_MAIL_FROM_NAME=TikStore
# MAIL_EHLO_DOMAIN=example.com

MAIL_FROM_ADDRESS=shop@example.com
MAIL_FROM_NAME=Shop
ADMIN_MAIL_ADDRESS=admin@example.com
ADMIN_MAIL_NAME=Admin
CONTACT_MAIL_ADDRESS=
CONTACT_MAIL_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_HOST=localhost
VITE_PORT=

# Crisp live chat on the Shop storefront (https://crisp.chat). Agents reply via Crisp web / mobile app.
# CRISP_WEBSITE_ID=

# Tawk.to live chat (https://www.tawk.to) on shop + admin panel. Same embed URL as storefront (see admin::components.layouts.embed-tawk).
# Optional: override IDs (defaults in config/services.php). Set either to empty to disable the widget.
# TAWK_PROPERTY_ID=
# TAWK_WIDGET_ID=

# Storefront branding (abuse / phishing safety). Keep false on public hosting.
# false = compliant copy, no TikTok trademarks, channel logo in header, disclaimer on landing/join.
# true  = restores previous TikTok Shop / TikTok Mall / TikStore wording and TikTok header image (legal risk).
STOREFRONT_LEGACY_TIKTOK_BRANDING=false
# Optional display name when legacy mode is off (defaults to APP_NAME).
# STOREFRONT_MARKETPLACE_NAME="My Marketplace"
